# Magnes Backend Environment Configuration

# --- AI API Configuration ---

# 默认 API 配置 (用于 Nano Banana/GPT-5 等)
API_KEY=your-sk-here
API_BASE_URL=https://ai.comfly.chat

# --- 图片分层API Configuration ---
# 请从 302.ai 控制台获取你的 API Key
API_302_KEY=your-sk-here
API_302_BASE_URL=https://api.302.ai

# --- Model Selection ---
# 策划与意图解析 (GPT-4o)
PLANNER_MODEL=gpt-4o
# 图层切偏(Qwen Layered)
DESIGNER_MODEL=qwen-image-layered
# 视觉分析 (GPT-4o) 
REFINER_MODEL=gpt-4o
# AI 背景重绘优化
PAINTER_MODEL=nano-banana-2
# 合规与审核
REVIEWER_MODEL=gpt-4o

# --- Database & Persistence ---
# LangGraph SQLite 检查点路径
CHECKPOINT_SQLITE_PATH=./data/magnes_checkpoints.db
# RAG 索引存储路径
VECTOR_INDEX_DIR=./data/vector_index

# --- Server Configuration ---
HOST=0.0.0.0
PORT=8000
DEBUG=True


